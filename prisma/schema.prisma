generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MovementClass {
  slow
  medium
  fast
}

// 1. Admins Table
model Admin {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

/// Singleton shop configuration (row id must stay `1`).
model ShopSettings {
  id     Int @id @default(1)
  /// Digits only (wa.me); null/empty → fall back to WHATSAPP_BUSINESS_PHONE env.
  whatsappPhoneDigits      String? @db.VarChar(20)
  whatsappGreetingNameEn   String? @db.VarChar(128)
  whatsappGreetingNameAr   String? @db.VarChar(128)
  /// Applied when creating a product if the API omits per-product thresholds.
  defaultStockAlertFast    Int?
  defaultStockAlertMedium  Int?
  defaultStockAlertSlow    Int?
  /// Admin low-stock list: slow SKU when stockQuantity is at or below this (usually 0).
  lowStockSlowAtOrBelow Int @default(0)
  /// Medium movement: low when stockQuantity is strictly below this value.
  lowStockMediumBelow   Int @default(3)
  /// Fast movement: low when stockQuantity is strictly below this value.
  lowStockFastBelow     Int @default(7)
  updatedAt             DateTime @updatedAt
}

// 2. Categories Table
model Category {
  id        Int        @id @default(autoincrement())
  parentId  Int?
  nameEn    String
  nameAr    String
  slug      String     @unique
  parent    Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children  Category[] @relation("SubCategories")
  products  Product[]
}

// 3. Products Table
model Product {
  id            String         @id @default(uuid())
  sku           String         @unique
  movementClass MovementClass  @default(medium)
  categoryId    Int
  brandName     String // e.g., Bosch, Genuine
  nameEn        String
  nameAr        String
  descEn        String?
  descAr        String?
  price         Decimal        @db.Decimal(10, 2)
  compareAtPrice Decimal?      @db.Decimal(10, 2)
  stockQuantity Int            @default(0)
  lowStockIgnored Boolean      @default(false)
  isFeatured    Boolean        @default(false)
  isActive      Boolean        @default(true)
  dimensions    String?
  weight        Float?
  manufacturedIn String?
  generation    String?
  condition     String         @default("new") // new, used
  stockAlertThresholdFast   Int?
  stockAlertThresholdMedium Int?
  stockAlertThresholdSlow   Int?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  category Category       @relation(fields: [categoryId], references: [id])
  images   ProductImage[]
  fitments Fitment[] // Bridge to Vehicles
  oems     ProductOem[]
}

model ProductOem {
  id        String  @id @default(uuid())
  productId String
  value     String  @db.VarChar(200)
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, value])
  @@index([value])
}

// 4. Product Images Table
model ProductImage {
  id        String  @id @default(uuid())
  urlThumb  String
  urlLarge  String
  isMain    Boolean @default(false)
  sortOrder Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// 5. Vehicles Table (The Car Library)
model Vehicle {
  id          Int       @id @default(autoincrement())
  nameEn      String    @default("")
  nameAr      String    @default("")
  brand       String    // e.g., BMW
  series      String    // e.g., 5 Series
  specifics   String    // e.g., 530i
  chassisCode String    // e.g., E60
  yearRange   String    // e.g., 2004-2010
  generation  String?   @db.VarChar(128)
  fitments    Fitment[] // Bridge to Products
}

// 6. Fitments Table (The Bridge / Pivot Table)
model Fitment {
  id        Int     @id @default(autoincrement())
  productId String
  vehicleId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([productId, vehicleId]) // Prevents duplicate fitment entries
}