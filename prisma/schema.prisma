generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MovementClass {
  slow
  medium
  fast
}

// 1. Admins Table
model Admin {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

// 2. Categories Table
model Category {
  id        Int        @id @default(autoincrement())
  parentId  Int?
  nameEn    String
  nameAr    String
  slug      String     @unique
  parent    Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children  Category[] @relation("SubCategories")
  products  Product[]
}

// 3. Products Table
model Product {
  id             String         @id @default(uuid())
  sku            String         @unique
  oemNumber      String?        
  movementClass  MovementClass  @default(medium)
  categoryId     Int
  brandName      String         // e.g., Bosch, Genuine
  nameEn         String
  nameAr         String
  descEn         String?
  descAr         String?
  price          Decimal        @db.Decimal(10, 2)
  compareAtPrice Decimal?       @db.Decimal(10, 2)
  stockQuantity  Int            @default(0)
  lowStockIgnored Boolean       @default(false)
  isFeatured     Boolean        @default(false)
  isActive       Boolean        @default(true)
  dimensions     String?
  weight         Float?
  manufacturedIn String?
  generation     String?
  condition      String         @default("new") // new, used
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  
  category       Category       @relation(fields: [categoryId], references: [id])
  images         ProductImage[]
  fitments       Fitment[]      // Bridge to Vehicles
  

  @@index([oemNumber])
}

// 4. Product Images Table
model ProductImage {
  id        String  @id @default(uuid())
  urlThumb  String
  urlLarge  String
  isMain    Boolean @default(false)
  sortOrder Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// 5. Vehicles Table (The Car Library)
model Vehicle {
  id          Int       @id @default(autoincrement())
  nameEn      String    @default("")
  nameAr      String    @default("")
  brand       String    // e.g., BMW
  series      String    // e.g., 5 Series
  specifics   String    // e.g., 530i
  chassisCode String    // e.g., E60
  yearRange   String    // e.g., 2004-2010
  fitments    Fitment[] // Bridge to Products
}

// 6. Fitments Table (The Bridge / Pivot Table)
model Fitment {
  id        Int     @id @default(autoincrement())
  productId String
  vehicleId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([productId, vehicleId]) // Prevents duplicate fitment entries
}